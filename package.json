{
  "name": "chanfana-vite-kumo-template",
  "private": true,
  "description": "A template for building a React application with Vite, Chanfana, Kumo UI and Cloudflare Workers",
  "type": "module",
  "scripts": {
    "build": "tsc -b && vite build",
    "cf-typegen": "wrangler types",
    "check": "tsc && vite build && wrangler deploy --dry-run",
    "deploy": "wrangler deploy",
    "dev": "vite",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check .",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "preview": "pnpm run build && vite preview"
  },
  "dependencies": {
    "@cloudflare/kumo": "^1.10.0",
    "@phosphor-icons/react": "^2.1.10",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-form": "^1.28.4",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-router": "^1.166.7",
    "@tanstack/react-router-devtools": "^1.166.7",
    "@tanstack/react-table": "^8.21.3",
    "chanfana": "^3.2.1",
    "hono": "^4.12.7",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.27.0",
    "@cloudflare/vitest-pool-workers": "^0.12.21",
    "@tanstack/router-plugin": "^1.166.7",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "oxfmt": "^0.39.0",
    "oxlint-tsgolint": "^0.16.0",
    "typescript": "^5.9.3",
    "vite": "^6.0.0",
    "vitest": "^3.2.4",
    "wrangler": "^4.72.0"
  },
  "cloudflare": {
    "label": "Chanfana + Vite + Kumo UI Template",
    "products": [
      "Workers"
    ],
    "categories": [],
    "preview_icon_url": "https://imagedelivery.net/wSMYJvS3Xw-n339CbDyDIA/532a5378-9717-4964-385b-5fafd2160200/public",
    "preview_image_url": "https://imagedelivery.net/wSMYJvS3Xw-n339CbDyDIA/ec7f4be5-d1d6-4e94-0851-126341745400/preview",
    "publish": true
  }
}
